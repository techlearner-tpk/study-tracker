generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum LearningStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum HabitGoalMetric {
  STUDY_MINUTES_DAILY
  STUDY_DAYS_WEEKLY
  STUDY_SESSION_DAILY
}

enum OutcomeGoalType {
  COMPLETE_TOPIC
  COMPLETE_CHAPTER
}

enum UserRole {
  PARENT
  KID
}

enum MagicLinkType {
  SIGNUP
  SIGNIN
  INVITE
}

enum CurriculumStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CurriculumVerificationStatus {
  OFFICIAL
  VERIFIED_FROM_OFFICIAL_SOURCE
  CURATED_FROM_OFFICIAL_SOURCE
  REVIEW_REQUIRED
}

enum AssignmentSource {
  PARENT
  SELF
}

enum AssignmentType {
  STUDY
  PRACTICE
  REVISION
  TEST
}

enum AssignmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  SKIPPED
}

enum AssignmentPriority {
  LOW
  MEDIUM
  HIGH
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AiLearningMode {
  TEACH
  TEST
}

enum AiSessionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum AiLearningMessageRole {
  SYSTEM
  CHILD
  ASSISTANT
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  clerkUserId  String?       @unique
  role         UserRole      @default(PARENT)
  verifiedAt   DateTime?
  childId      String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  child        Child?        @relation("KidChild", fields: [childId], references: [id], onDelete: Cascade)
  children     Child[]       @relation("ParentChildren")
  assignments  Assignment[]  @relation("AssignmentsCreatedBy")
  subscription Subscription? @relation("ParentSubscription")
}

model Child {
  id                    String                 @id @default(cuid())
  userId                String?
  name                  String
  className             String
  school                String?
  themeColor            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User?                  @relation("ParentChildren", fields: [userId], references: [id], onDelete: Cascade)
  kidUser               User?                  @relation("KidChild")
  magicLinkTokens       MagicLinkToken[]
  subjects              Subject[]
  habitGoals            HabitGoal[]
  outcomeGoals          OutcomeGoal[]
  curriculumAssignments CurriculumAssignment[]
  assignments           Assignment[]
  aiTopicUsages         AiTopicUsage[]
  aiLearningSessions    AiLearningSession[]
  aiTestAttempts        AiTestAttempt[]

  @@index([name])
  @@index([userId])
}

model CurriculumBoard {
  id        String              @id @default(cuid())
  code      String              @unique
  name      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  versions  CurriculumVersion[]
}

model CurriculumVersion {
  id                    String                       @id @default(cuid())
  boardId               String
  academicYear          String
  version               String
  name                  String
  status                CurriculumStatus             @default(DRAFT)
  verificationStatus    CurriculumVerificationStatus @default(REVIEW_REQUIRED)
  sourceUrl             String?
  notes                 String?
  sourceReferences      Json?
  publishedAt           DateTime?
  archivedAt            DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  board                 CurriculumBoard              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  classes               CurriculumClass[]
  curriculumAssignments CurriculumAssignment[]

  @@unique([boardId, academicYear, version])
  @@index([boardId])
  @@index([status])
}

model CurriculumClass {
  id                    String                 @id @default(cuid())
  versionId             String
  level                 Int
  name                  String
  stableKey             String
  sequence              Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  version               CurriculumVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  subjects              CurriculumSubject[]
  curriculumAssignments CurriculumAssignment[]

  @@unique([versionId, level])
  @@unique([versionId, stableKey])
  @@index([versionId])
}

model CurriculumSubject {
  id                 String                       @id @default(cuid())
  classId            String
  stableKey          String
  name               String
  sequence           Int                          @default(0)
  isDefaultSelected  Boolean                      @default(false)
  isOptional         Boolean                      @default(false)
  isLanguageSubject  Boolean                      @default(false)
  sourceUrl          String?
  verificationStatus CurriculumVerificationStatus @default(REVIEW_REQUIRED)
  archivedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  class              CurriculumClass              @relation(fields: [classId], references: [id], onDelete: Cascade)
  chapters           CurriculumChapter[]

  @@unique([classId, stableKey])
  @@index([classId])
  @@index([archivedAt])
}

model CurriculumChapter {
  id                 String                       @id @default(cuid())
  subjectId          String
  stableKey          String
  name               String
  sequence           Int                          @default(0)
  sourceUrl          String?
  verificationStatus CurriculumVerificationStatus @default(REVIEW_REQUIRED)
  archivedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  subject            CurriculumSubject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics             CurriculumTopic[]

  @@unique([subjectId, stableKey])
  @@index([subjectId])
  @@index([archivedAt])
}

model CurriculumTopic {
  id                 String                       @id @default(cuid())
  chapterId          String
  stableKey          String
  name               String
  sequence           Int                          @default(0)
  sourceUrl          String?
  verificationStatus CurriculumVerificationStatus @default(REVIEW_REQUIRED)
  archivedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  chapter            CurriculumChapter            @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, stableKey])
  @@index([chapterId])
  @@index([archivedAt])
}

model CurriculumAssignment {
  id                  String            @id @default(cuid())
  childId             String            @unique
  curriculumVersionId String
  curriculumClassId   String
  selectedSubjectIds  String[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  child               Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  curriculumVersion   CurriculumVersion @relation(fields: [curriculumVersionId], references: [id], onDelete: Restrict)
  curriculumClass     CurriculumClass   @relation(fields: [curriculumClassId], references: [id], onDelete: Restrict)
  subjects            Subject[]
  chapters            Chapter[]
  topics              Topic[]
}

model Assignment {
  id                    String              @id @default(cuid())
  childId               String
  topicId               String
  assignedByUserId      String
  source                AssignmentSource
  type                  AssignmentType
  status                AssignmentStatus    @default(PLANNED)
  priority              AssignmentPriority  @default(MEDIUM)
  isActive              Boolean             @default(true)
  plannedDate           DateTime?
  dueDate               DateTime?
  instructions          String?
  studySessionTarget    Int?
  practiceSessionTarget Int?
  questionTarget        Int?
  maximumMarks          Int?
  passingMarks          Int?
  durationMinutes       Int?
  score                 Int?
  completedAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  child                 Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  topic                 Topic               @relation(fields: [topicId], references: [id], onDelete: Restrict)
  assignedBy            User                @relation("AssignmentsCreatedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)
  studySessions         StudySession[]
  practiceSessions      PracticeSession[]
  revisionSessions      RevisionSession[]
  aiLearningSessions    AiLearningSession[]
  aiTestAttempts        AiTestAttempt[]

  @@index([childId])
  @@index([topicId])
  @@index([assignedByUserId])
  @@index([status])
  @@index([dueDate])
}

model MagicLinkToken {
  id        String        @id @default(cuid())
  email     String
  type      MagicLinkType
  tokenHash String        @unique
  childId   String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  child     Child?        @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([childId])
  @@index([expiresAt])
}

model Subject {
  id                     String                @id @default(cuid())
  childId                String
  name                   String
  color                  String?
  order                  Int                   @default(0)
  curriculumAssignmentId String?
  curriculumVersionId    String?
  curriculumSubjectId    String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  child                  Child                 @relation(fields: [childId], references: [id], onDelete: Cascade)
  curriculumAssignment   CurriculumAssignment? @relation(fields: [curriculumAssignmentId], references: [id], onDelete: SetNull)
  chapters               Chapter[]

  @@unique([childId, name])
  @@index([childId])
  @@index([curriculumVersionId])
  @@index([curriculumAssignmentId])
}

model Chapter {
  id                     String                @id @default(cuid())
  subjectId              String
  name                   String
  order                  Int                   @default(0)
  curriculumAssignmentId String?
  curriculumVersionId    String?
  curriculumSubjectId    String?
  curriculumChapterId    String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  subject                Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculumAssignment   CurriculumAssignment? @relation(fields: [curriculumAssignmentId], references: [id], onDelete: SetNull)
  topics                 Topic[]

  @@index([subjectId])
  @@index([curriculumVersionId])
  @@index([curriculumAssignmentId])
}

model Topic {
  id                     String                @id @default(cuid())
  chapterId              String
  name                   String
  description            String?
  status                 LearningStatus        @default(NOT_STARTED)
  confidenceRating       Int?
  notes                  String?
  order                  Int                   @default(0)
  curriculumAssignmentId String?
  curriculumVersionId    String?
  curriculumSubjectId    String?
  curriculumChapterId    String?
  curriculumTopicId      String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  completedAt            DateTime?
  chapter                Chapter               @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  curriculumAssignment   CurriculumAssignment? @relation(fields: [curriculumAssignmentId], references: [id], onDelete: SetNull)
  studySessions          StudySession[]
  practiceSessions       PracticeSession[]
  revisionSessions       RevisionSession[]
  assignments            Assignment[]
  aiTopicUsages          AiTopicUsage[]
  aiLearningSessions     AiLearningSession[]
  aiTestAttempts         AiTestAttempt[]

  @@index([chapterId])
  @@index([status])
  @@index([curriculumVersionId])
  @@index([curriculumAssignmentId])
}

model StudySession {
  id              String      @id @default(cuid())
  topicId         String
  assignmentId    String?
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  notes           String?
  createdAt       DateTime    @default(now())
  topic           Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment      Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([topicId])
  @@index([assignmentId])
  @@index([startTime])
}

model PracticeSession {
  id                 String      @id @default(cuid())
  topicId            String
  assignmentId       String?
  date               DateTime
  durationMinutes    Int
  questionsAttempted Int?
  questionsCorrect   Int?
  notes              String?
  createdAt          DateTime    @default(now())
  topic              Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment         Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([topicId])
  @@index([assignmentId])
  @@index([date])
}

model RevisionSession {
  id              String      @id @default(cuid())
  topicId         String
  assignmentId    String?
  date            DateTime
  durationMinutes Int
  notes           String?
  createdAt       DateTime    @default(now())
  topic           Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment      Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([topicId])
  @@index([assignmentId])
  @@index([date])
}

model Subscription {
  id        String             @id @default(cuid())
  parentId  String             @unique
  status    SubscriptionStatus @default(FREE)
  planCode  String?
  startsAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  parent    User               @relation("ParentSubscription", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expiresAt])
}

model AiSetting {
  id                  Int      @id @default(1)
  topicPromptLimit    Int?
  testQuestionCount   Int?
  maxUserPromptLength Int?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model AiRequestLog {
  id        String   @id @default(cuid())
  requestId String   @unique
  operation String
  sessionId String?
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operation])
  @@index([sessionId])
}

model AiTopicUsage {
  id          String   @id @default(cuid())
  childId     String
  topicId     String
  promptCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([childId, topicId])
  @@index([childId])
  @@index([topicId])
}

model AiLearningSession {
  id            String              @id @default(cuid())
  childId       String
  topicId       String
  assignmentId  String?
  mode          AiLearningMode
  status        AiSessionStatus     @default(ACTIVE)
  provider      String
  model         String
  promptVersion String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  child         Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  topic         Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment    Assignment?         @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  messages      AiLearningMessage[]
  testAttempt   AiTestAttempt?

  @@index([childId])
  @@index([topicId])
  @@index([assignmentId])
  @@index([status])
  @@index([mode])
}

model AiLearningMessage {
  id        String                @id @default(cuid())
  sessionId String
  role      AiLearningMessageRole
  content   String
  sequence  Int
  createdAt DateTime              @default(now())
  session   AiLearningSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
}

model AiTestAttempt {
  id              String            @id @default(cuid())
  sessionId       String            @unique
  childId         String
  topicId         String
  assignmentId    String?
  questionCount   Int
  correctCount    Int
  scorePercentage Int
  startedAt       DateTime
  submittedAt     DateTime?
  questionsJson   Json
  answersJson     Json?
  evaluationJson  Json?
  createdAt       DateTime          @default(now())
  session         AiLearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  child           Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  topic           Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  assignment      Assignment?       @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([childId])
  @@index([topicId])
  @@index([assignmentId])
}

model HabitGoal {
  id          String          @id @default(cuid())
  childId     String
  title       String
  metric      HabitGoalMetric
  targetValue Int
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  child       Child           @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

model OutcomeGoal {
  id              String          @id @default(cuid())
  childId         String
  title           String
  type            OutcomeGoalType
  targetTopicId   String?
  targetChapterId String?
  dueDate         DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  child           Child           @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([targetTopicId])
  @@index([targetChapterId])
}
